# Optional overrides
MARKETING_FOUNDATIONS_BASE_URL=https://marketing-foundations.bigbrain.me
# Pin a campaign-explore build version (defaults to latest from mf-assets)
# CAMPAIGN_EXPLORE_BUILD_VERSION=155
# Personal folder in campaign-explore (git user.name / display name)
# e.g. your git config user.name (campaign-explore sidebar folder)
Z2H_EXPLORE_PERSONAL_FOLDER=Your Display Name
# personal (default) | shared
Z2H_EXPLORE_DEFAULT_STORAGE=personal
# Optional auth if writes fail without VPN/session
# BIGBRAIN_AUTH_TOKEN=
# BIGBRAIN_SESSION_COOKIE=